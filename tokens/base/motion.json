{
  "duration": {
    "instant": { "$value": "0ms",   "$type": "other" },
    "fast":    { "$value": "100ms", "$type": "other" },
    "normal":  { "$value": "200ms", "$type": "other" },
    "slow":    { "$value": "300ms", "$type": "other" },
    "glacial": { "$value": "500ms", "$type": "other" }
  },
  "ease": {
    "in":      { "$value": "cubic-bezier(0.4, 0, 1, 1)",         "$type": "other" },
    "out":     { "$value": "cubic-bezier(0, 0, 0.2, 1)",         "$type": "other" },
    "spring":  { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)",  "$type": "other" },
    "precise": { "$value": "cubic-bezier(0.25, 0.46, 0.45, 0.94)", "$type": "other" }
  },
  "transition": {
    "fast":   { "$value": "100ms ease",                                    "$type": "other" },
    "base":   { "$value": "150ms ease",                                    "$type": "other" },
    "slow":   { "$value": "250ms ease",                                    "$type": "other" },
    "spring": { "$value": "300ms cubic-bezier(0.34, 1.56, 0.64, 1)",      "$type": "other" }
  }
}
