{
  "shadow": {
    "none": {
      "$value": "none",
      "$type": "shadow"
    },
    "xs": {
      "$value": "0px 1px 2px 0px rgba(0, 0, 0, 0.05)",
      "$type": "shadow"
    },
    "sm": {
      "$value": "0px 1px 3px 0px rgba(0, 0, 0, 0.08), 0px 1px 2px -1px rgba(0, 0, 0, 0.06)",
      "$type": "shadow"
    },
    "md": {
      "$value": "0px 4px 6px -1px rgba(0, 0, 0, 0.07), 0px 2px 4px -2px rgba(0, 0, 0, 0.05)",
      "$type": "shadow"
    },
    "lg": {
      "$value": "0px 10px 15px -3px rgba(0, 0, 0, 0.07), 0px 4px 6px -4px rgba(0, 0, 0, 0.05)",
      "$type": "shadow"
    },
    "xl": {
      "$value": "0px 20px 25px -5px rgba(0, 0, 0, 0.08), 0px 8px 10px -6px rgba(0, 0, 0, 0.04)",
      "$type": "shadow"
    },
    "2xl": {
      "$value": "0px 25px 50px -12px rgba(0, 0, 0, 0.18)",
      "$type": "shadow"
    },
    "inner": {
      "$value": "inset 0px 2px 4px 0px rgba(0, 0, 0, 0.05)",
      "$type": "shadow"
    },
    "focus-ring": {
      "$value": "0px 0px 0px 3px rgba(99, 102, 241, 0.35)",
      "$type": "shadow"
    },
    "focus-ring-error": {
      "$value": "0px 0px 0px 3px rgba(239, 68, 68, 0.35)",
      "$type": "shadow"
    }
  }
}
